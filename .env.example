# Firebase Authentication
# Base64-encoded service account JSON. Generate with:
#   base64 -i firebase-service-account.json | tr -d '\n'
# Used both for Auth (verifying ID tokens / session cookies, custom claims)
# and for FCM push notifications.
FIREBASE_SERVICE_ACCOUNT_BASE64=

# BBB API Configuration
BBB_SERVER_BASE_URL=
BBB_SECRET=
PLUGIN_MANIFESTS_URL=

# Broadcaster configuration
BROADCASTER_API_URL=

# Twitch IRC connection
TWITCH_SERVER=
TWITCH_PORT=
TWITCH_NICK=
TWITCH_CHANNEL=

# Twitch OAuth client credentials flow
TWITCH_REDIRECT_URI=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_TOKEN_URL=
# TWITCH_USER_ACCESS_TOKEN=

# Database configuration
DB_URL=
# Connection pool tuning (defaults are good for moderate prod load).
# Raise DB_POOL_SIZE if connection acquisition shows up as a hot path
# in tracing — it's the main lever for high-concurrency workers.
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=true

# Environment
ENV=

# Token encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=

# Base URL for the API
API_BASE_URL=


DOMAIN=

# YouTube OAuth
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=

# Facebook OAuth (create app at https://developers.facebook.com)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=

# Chat Gateway
CHAT_GATEWAY_URL=http://localhost:8081
CHAT_GATEWAY_SHARED_SECRET=

# Redis & Caching
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=1800
CACHE_TTL_LONG=3600
CACHE_TTL_USER=900
CACHE_TTL_BBB=180

# Stripe Payment Configuration
# Get these from https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products in Stripe Dashboard and copy the Price IDs (starting with price_)
STRIPE_FREE_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
TOKEN_ENCRYPTION_KEY=
CORS_ORIGIN_REGEX=




# Rate limiting for auth + payment endpoints. SlowAPI syntax: "<count>/<window>".
# Backed by Redis (REDIS_URL) so multi-worker / multi-pod deployments share
# state; falls back to in-memory if Redis is unreachable. Leave RATE_LIMIT_ENABLED
# as true in prod — false is an emergency override only.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_TOKEN=20/minute
RATE_LIMIT_REFRESH=30/minute
RATE_LIMIT_DEV_TOKEN=5/minute
RATE_LIMIT_PAYMENTS=60/minute

# SMTP (Gmail / Workspace — generate an App Password at https://myaccount.google.com/apppasswords)
# For other providers (Brevo, SendGrid, SES …) override host/port/STARTTLS accordingly.
# Note: SMTP_FROM_EMAIL must equal SMTP_USERNAME (or one of its configured aliases),
# otherwise Gmail will rewrite the From: header.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=contact@yourdomain.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=contact@yourdomain.com
SMTP_FROM_NAME=BlueScale
SMTP_USE_STARTTLS=false